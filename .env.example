# 个人记事本 — 环境配置
# 复制此文件为 .env 并修改配置：
#   cp .env.example .env

# Django 密钥 — 生产环境请用 python -c "import secrets; print(secrets.token_urlsafe(50))" 生成
SECRET_KEY=请在此填入随机密钥

# 调试模式：True=开发 / False=生产
DEBUG=True

# 本地模式：True=仅本机可访问 / False=允许外部访问
LOCAL_MODE=True

# CSRF 可信来源 — 部署到非 localhost 时需要配置（多个用逗号分隔）
# 例如：CSRF_TRUSTED_ORIGINS=https://mynotepad.example.com,https://192.168.1.100:8000
CSRF_TRUSTED_ORIGINS=
